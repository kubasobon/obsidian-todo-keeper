{
    "name": "obsidian-todo-keeper",
    "version": "0.0.1",
    "description": "Keeps incomplete todos from your previous daily note into today's",
    "main": "main.js",
    "author": "Kuba Soboń",
    "authorUrl": "https://kubasobon.com",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/kubasobon/obsidian-todo-keeper.git"
    },
    "homepage": "https://github.com/kubasobon/obsidian-todo-keeper",
    "keywords": [
        "obsidian",
        "plugin",
        "todo",
        "keeper",
        "daily-notes"
    ],
    "scripts": {
        "dev": "vite --watch",
        "build": "vite build",
        "test": "jest",
        "test:watch": "jest --watch",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src/",
        "format": "prettier --write ."
