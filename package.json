        "eslint": "^8.50.0",
        "jest": "^29.5.0",
        "obsidian": "https://github.com/obsidianmd/obsidian-api/tarball/master",
        "prettier": "^3.0.0",
        "ts-jest": "^29.1.0",
        "typescript": "^5.9.3",
        "vite": "^5.0.0"
    },
    "dependencies": {
        "obsidian-daily-notes-interface": "^0.9.2"
